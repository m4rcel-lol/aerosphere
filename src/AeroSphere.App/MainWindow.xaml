<Window
    x:Class="AeroSphere.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="AeroSphere"
    Width="1380"
    Height="900"
    MinWidth="1180"
    MinHeight="720"
    Background="{StaticResource WindowBackgroundBrush}"
    WindowStartupLocation="CenterScreen">

    <Grid Background="{StaticResource WindowBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="272" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border
            Grid.Column="0"
            Background="{StaticResource PaneBackgroundBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,0,1,0"
            Padding="24">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Style="{StaticResource AppTitleTextStyle}" Text="AeroSphere" />
                    <TextBlock
                        Margin="0,6,0,0"
                        Style="{StaticResource CaptionTextStyle}"
                        Text="Windows 10 style desktop dashboard built on pure .NET 8 WPF." />

                    <Border
                        Margin="0,24,0,0"
                        Style="{StaticResource PanelCardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="Current time" />
                            <TextBlock
                                Margin="0,8,0,0"
                                Style="{StaticResource SidebarPrimaryValueTextStyle}"
                                Text="{Binding CurrentTime}" />
                            <TextBlock
                                Margin="0,4,0,0"
                                Style="{StaticResource CaptionTextStyle}"
                                Text="{Binding CurrentDate}" />
                        </StackPanel>
                    </Border>

                    <Border
                        Margin="0,16,0,0"
                        Style="{StaticResource PanelCardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="System" />
                            <TextBlock
                                Margin="0,8,0,0"
                                Style="{StaticResource SidebarSecondaryValueTextStyle}"
                                Text="{Binding MachineName}" />
                            <TextBlock
                                Margin="0,4,0,0"
                                Style="{StaticResource CaptionTextStyle}"
                                Text="{Binding StatusMessage}" />
                            <TextBlock
                                Margin="0,12,0,0"
                                Style="{StaticResource CaptionTextStyle}"
                                Text="{Binding LastRefreshLabel}" />
                        </StackPanel>
                    </Border>

                    <Button
                        Margin="0,18,0,0"
                        Command="{Binding RefreshCommand}"
                        Content="Refresh Dashboard"
                        Style="{StaticResource AccentButtonStyle}" />

                    <TextBlock
                        Margin="0,24,0,10"
                        Style="{StaticResource SectionLabelTextStyle}"
                        Text="Pinned actions" />

                    <ItemsControl ItemsSource="{Binding PinnedLaunchers}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button
                                    Margin="0,0,0,8"
                                    Command="{Binding DataContext.LaunchAppCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    Content="{Binding Name}"
                                    Style="{StaticResource FlatButtonStyle}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Style="{StaticResource PageTitleTextStyle}" Text="{Binding HeroTitle}" />
                <TextBlock
                    Margin="0,6,0,0"
                    Style="{StaticResource BodyTextStyle}"
                    Text="{Binding HeroSubtitle}"
                    TextWrapping="Wrap" />
            </StackPanel>

            <TabControl
                Grid.Row="1"
                Margin="0,24,0,0"
                ItemContainerStyle="{StaticResource Windows10TabItemStyle}">
                <TabItem Header="Overview">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,8,0,0">
                            <Border Style="{StaticResource HeroPanelStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="Desktop summary" />
                                        <TextBlock
                                            Margin="0,10,0,0"
                                            Style="{StaticResource HeroTitleTextStyle}"
                                            Text="{Binding HeroTitle}" />
                                        <TextBlock
                                            Margin="0,8,0,0"
                                            Style="{StaticResource BodyTextStyle}"
                                            Text="{Binding HeroSubtitle}"
                                            TextWrapping="Wrap" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Margin="24,0,0,0" Width="260">
                                        <Border Margin="0,0,0,10" Style="{StaticResource PanelCardStyle}">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="Last refresh" />
                                                <TextBlock
                                                    Margin="0,8,0,0"
                                                    Style="{StaticResource CardValueTextStyle}"
                                                    Text="{Binding LastRefreshLabel}" />
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource PanelCardStyle}">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="Status" />
                                                <TextBlock
                                                    Margin="0,8,0,0"
                                                    Style="{StaticResource CardValueTextStyle}"
                                                    Text="{Binding StatusMessage}"
                                                    TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <TextBlock
                                Margin="0,24,0,12"
                                Style="{StaticResource SectionHeaderTextStyle}"
                                Text="Live components" />

                            <ItemsControl ItemsSource="{Binding OverviewCards}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            Width="255"
                                            Margin="0,0,16,16"
                                            Style="{StaticResource PanelCardStyle}">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="{Binding Title}" />
                                                <TextBlock
                                                    Margin="0,10,0,0"
                                                    Style="{StaticResource CardValueTextStyle}"
                                                    Text="{Binding Value}" />
                                                <TextBlock
                                                    Margin="0,8,0,0"
                                                    Style="{StaticResource CaptionTextStyle}"
                                                    Text="{Binding Detail}"
                                                    TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock
                                Margin="0,8,0,12"
                                Style="{StaticResource SectionHeaderTextStyle}"
                                Text="Quick actions" />

                            <ItemsControl ItemsSource="{Binding AppLaunchers}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            Width="255"
                                            Margin="0,0,16,16"
                                            Style="{StaticResource PanelCardStyle}">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource CardTitleTextStyle}" Text="{Binding Name}" />
                                                <TextBlock
                                                    Margin="0,8,0,12"
                                                    Style="{StaticResource CaptionTextStyle}"
                                                    Text="{Binding Description}"
                                                    TextWrapping="Wrap" />
                                                <Button
                                                    Command="{Binding DataContext.LaunchAppCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Content="Open"
                                                    Style="{StaticResource FlatButtonStyle}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Recent Files">
                    <Grid Margin="0,16,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock
                            Style="{StaticResource BodyTextStyle}"
                            Text="Uses the Windows Recent folder when available, then falls back to the latest files from common user locations." />

                        <ListView
                            Grid.Row="1"
                            Margin="0,16,0,0"
                            ItemsSource="{Binding RecentFiles}"
                            Style="{StaticResource FlatListViewStyle}">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Width="220" Header="Name" DisplayMemberBinding="{Binding DisplayName}" />
                                    <GridViewColumn Width="310" Header="Source" DisplayMemberBinding="{Binding SourceLabel}" />
                                    <GridViewColumn Width="170" Header="Modified" DisplayMemberBinding="{Binding LastModifiedLabel}" />
                                    <GridViewColumn Width="120" Header="Action">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button
                                                    Command="{Binding DataContext.OpenRecentFileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Content="Open"
                                                    Style="{StaticResource FlatButtonStyle}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </TabItem>

                <TabItem Header="Folders">
                    <Grid Margin="0,16,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock
                            Style="{StaticResource BodyTextStyle}"
                            Text="Shows your most recently changed common folders so the dashboard remains useful even without cloud accounts or shell integrations." />

                        <ListView
                            Grid.Row="1"
                            Margin="0,16,0,0"
                            ItemsSource="{Binding RecentFolders}"
                            Style="{StaticResource FlatListViewStyle}">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Width="210" Header="Folder" DisplayMemberBinding="{Binding DisplayName}" />
                                    <GridViewColumn Width="360" Header="Path" DisplayMemberBinding="{Binding FullPath}" />
                                    <GridViewColumn Width="150" Header="Updated" DisplayMemberBinding="{Binding LastModifiedLabel}" />
                                    <GridViewColumn Width="120" Header="Items" DisplayMemberBinding="{Binding ItemCountLabel}" />
                                    <GridViewColumn Width="120" Header="Action">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button
                                                    Command="{Binding DataContext.OpenRecentFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Content="Open"
                                                    Style="{StaticResource FlatButtonStyle}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </TabItem>

                <TabItem Header="Apps">
                    <ScrollViewer Margin="0,16,0,0" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding AppLaunchers}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Width="260"
                                        Margin="0,0,16,16"
                                        Style="{StaticResource PanelCardStyle}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource CardTitleTextStyle}" Text="{Binding Name}" />
                                            <TextBlock
                                                Margin="0,8,0,14"
                                                Style="{StaticResource CaptionTextStyle}"
                                                Text="{Binding Description}"
                                                TextWrapping="Wrap" />
                                            <Button
                                                Command="{Binding DataContext.LaunchAppCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Content="Launch"
                                                Style="{StaticResource FlatButtonStyle}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="System">
                    <ScrollViewer Margin="0,16,0,0" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeaderTextStyle}" Text="System facts" />
                            <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding SystemFacts}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,8" Style="{StaticResource PanelCardStyle}">
                                            <DockPanel LastChildFill="True">
                                                <TextBlock
                                                    DockPanel.Dock="Left"
                                                    Width="190"
                                                    Style="{StaticResource SectionLabelTextStyle}"
                                                    Text="{Binding Label}" />
                                                <TextBlock
                                                    Style="{StaticResource BodyTextStyle}"
                                                    Text="{Binding Value}"
                                                    TextWrapping="Wrap" />
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock
                                Margin="0,24,0,12"
                                Style="{StaticResource SectionHeaderTextStyle}"
                                Text="Storage" />

                            <ListView ItemsSource="{Binding DriveSnapshots}" Style="{StaticResource FlatListViewStyle}">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Width="120" Header="Drive" DisplayMemberBinding="{Binding Name}" />
                                        <GridViewColumn Width="170" Header="Free space" DisplayMemberBinding="{Binding FreeSpaceLabel}" />
                                        <GridViewColumn Width="170" Header="Total space" DisplayMemberBinding="{Binding TotalSpaceLabel}" />
                                        <GridViewColumn Width="220" Header="Usage" DisplayMemberBinding="{Binding UsageLabel}" />
                                    </GridView>
                                </ListView.View>
                            </ListView>

                            <TextBlock
                                Margin="0,24,0,12"
                                Style="{StaticResource SectionHeaderTextStyle}"
                                Text="Network" />

                            <ListView ItemsSource="{Binding NetworkSnapshots}" Style="{StaticResource FlatListViewStyle}">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Width="260" Header="Adapter" DisplayMemberBinding="{Binding Name}" />
                                        <GridViewColumn Width="160" Header="Status" DisplayMemberBinding="{Binding Status}" />
                                        <GridViewColumn Width="340" Header="Address" DisplayMemberBinding="{Binding AddressText}" />
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>
