<Window
    x:Class="AeroSphere.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:AeroSphere.App.Models"
    mc:Ignorable="d"
    Title="AeroSphere">

    <Grid Background="{ThemeResource AppShellBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="88" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border
            Grid.Column="0"
            Background="{ThemeResource NavigationRailBackgroundBrush}"
            BorderBrush="{ThemeResource ShellDividerBrush}"
            BorderThickness="0,0,1,0">
            <controls:NavigationView
                Background="Transparent"
                CompactPaneLength="88"
                IsBackButtonVisible="Collapsed"
                IsPaneOpen="True"
                IsPaneToggleButtonVisible="False"
                IsSettingsVisible="False"
                OpenPaneLength="88"
                PaneDisplayMode="LeftCompact"
                SelectionFollowsFocus="Enabled">
                <controls:NavigationView.PaneHeader>
                    <StackPanel
                        Margin="0,8,0,20"
                        HorizontalAlignment="Center"
                        Spacing="10">
                        <Border
                            Width="40"
                            Height="40"
                            Background="{ThemeResource AccentSurfaceBrush}"
                            CornerRadius="20">
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="18"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource AccentTextBrush}"
                                Text="A" />
                        </Border>
                        <TextBlock
                            HorizontalAlignment="Center"
                            Foreground="{ThemeResource AccentTextBrush}"
                            Opacity="0.86"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Text="AeroSphere" />
                    </StackPanel>
                </controls:NavigationView.PaneHeader>
                <controls:NavigationView.MenuItems>
                    <controls:NavigationViewItem Content="Dashboard" Icon="Home" />
                    <controls:NavigationViewItem Content="Activity" Icon="Clock" />
                    <controls:NavigationViewItem Content="Files" Icon="Document" />
                    <controls:NavigationViewItem Content="Apps" Icon="AllApps" />
                    <controls:NavigationViewItem Content="System" Icon="Admin" />
                    <controls:NavigationViewItem Content="Shortcuts" Icon="Pin" />
                </controls:NavigationView.MenuItems>
                <controls:NavigationView.FooterMenuItems>
                    <controls:NavigationViewItem Content="Settings" Icon="Setting" />
                </controls:NavigationView.FooterMenuItems>
            </controls:NavigationView>
        </Border>

        <Grid Grid.Column="1" Padding="24,20,24,24" RowSpacing="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <AutoSuggestBox
                    Grid.Column="0"
                    MinWidth="380"
                    PlaceholderText="Search apps, files, folders, settings, and commands (Ctrl+K)"
                    QueryIcon="Find" />

                <Border
                    Grid.Column="1"
                    Margin="4,0,0,0"
                    Background="{ThemeResource StatSurfaceBrush}"
                    CornerRadius="14"
                    Padding="14,10">
                    <TextBlock
                        Foreground="{ThemeResource AccentTextBrush}"
                        Style="{ThemeResource BodyStrongTextBlockStyle}"
                        Text="{x:Bind ViewModel.WeatherSummary, Mode=OneWay}" />
                </Border>

                <Border
                    Grid.Column="2"
                    Background="{ThemeResource StatSurfaceBrush}"
                    CornerRadius="14"
                    Padding="14,10">
                    <TextBlock
                        Style="{ThemeResource BodyTextBlockStyle}"
                        Text="{x:Bind ViewModel.TimeSummary, Mode=OneWay}" />
                </Border>

                <Button
                    Grid.Column="3"
                    Margin="8,0,0,0"
                    Command="{x:Bind ViewModel.RefreshCommand}"
                    Content="Refresh" />
            </Grid>

            <Border Grid.Row="1" Style="{StaticResource HeroPanelStyle}">
                <Grid ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="14">
                        <TextBlock
                            Foreground="{ThemeResource AccentTextBrush}"
                            Style="{StaticResource DashboardKickerTextStyle}"
                            Text="Personal dashboard" />
                        <TextBlock
                            FontSize="32"
                            FontWeight="SemiBold"
                            Text="{x:Bind ViewModel.HeaderTitle}"
                            TextWrapping="WrapWholeWords" />
                        <TextBlock
                            Foreground="{ThemeResource CardMutedBrush}"
                            FontSize="14"
                            Text="{x:Bind ViewModel.HeaderSubtitle}"
                            TextWrapping="WrapWholeWords" />
                        <TextBlock
                            FontSize="16"
                            FontWeight="Medium"
                            Text="{x:Bind ViewModel.FocusSummary, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <Grid Grid.Column="1" RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Style="{StaticResource DashboardStatStyle}">
                            <StackPanel Spacing="4">
                                <TextBlock Style="{StaticResource DashboardMetaTextStyle}" Text="Status" />
                                <TextBlock
                                    Style="{StaticResource DashboardValueTextStyle}"
                                    Text="{x:Bind ViewModel.StatusSummary, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Style="{StaticResource DashboardStatStyle}">
                            <StackPanel Spacing="4">
                                <TextBlock Style="{StaticResource DashboardMetaTextStyle}" Text="Last refresh" />
                                <TextBlock
                                    Style="{StaticResource DashboardValueTextStyle}"
                                    Text="{x:Bind ViewModel.LastUpdated, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2" Style="{StaticResource DashboardStatStyle}">
                            <StackPanel Spacing="4">
                                <TextBlock Style="{StaticResource DashboardMetaTextStyle}" Text="Privacy" />
                                <TextBlock
                                    Style="{StaticResource DashboardValueTextStyle}"
                                    Text="Local-first shell with clear places to add opt-in providers."
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <GridView
                Grid.Row="2"
                HorizontalAlignment="Stretch"
                IsItemClickEnabled="False"
                ItemsSource="{x:Bind ViewModel.Widgets, Mode=OneWay}"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                ScrollViewer.HorizontalScrollMode="Disabled"
                ScrollViewer.VerticalScrollBarVisibility="Auto"
                ScrollViewer.VerticalScrollMode="Enabled"
                SelectionMode="None">
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid
                            ItemHeight="216"
                            ItemWidth="340"
                            Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>
                <GridView.ItemContainerStyle>
                    <Style TargetType="GridViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Margin" Value="0,0,16,16" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="VerticalContentAlignment" Value="Stretch" />
                    </Style>
                </GridView.ItemContainerStyle>
                <GridView.ItemTemplate>
                    <DataTemplate x:DataType="models:WidgetDefinition">
                        <Border Style="{StaticResource DashboardCardStyle}">
                            <Grid RowSpacing="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock
                                    Style="{StaticResource DashboardKickerTextStyle}"
                                    Text="{x:Bind Category}" />
                                <TextBlock
                                    Grid.Row="1"
                                    FontSize="22"
                                    FontWeight="SemiBold"
                                    Text="{x:Bind Title}"
                                    TextWrapping="WrapWholeWords" />
                                <TextBlock
                                    Grid.Row="2"
                                    Foreground="{ThemeResource CardMutedBrush}"
                                    Text="{x:Bind Summary}"
                                    TextWrapping="WrapWholeWords" />

                                <Grid Grid.Row="3" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Spacing="2">
                                        <TextBlock Style="{StaticResource DashboardMetaTextStyle}" Text="Primary" />
                                        <TextBlock
                                            Style="{StaticResource DashboardValueTextStyle}"
                                            Text="{x:Bind PrimaryValue}"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Style="{StaticResource DashboardMetaTextStyle}" Text="Details" />
                                        <TextBlock
                                            Style="{StaticResource DashboardValueTextStyle}"
                                            Text="{x:Bind SecondaryValue}"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
        </Grid>
    </Grid>
</Window>
