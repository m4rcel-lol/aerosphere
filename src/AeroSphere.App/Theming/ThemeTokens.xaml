<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="AppShellBackgroundBrush" Color="#0F1115" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#1A1F27" />
    <SolidColorBrush x:Key="CardBorderBrush" Color="#2B3442" />

    <Style x:Key="DashboardCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="Margin" Value="0,0,12,12" />
        <Setter Property="MinHeight" Value="160" />
    </Style>
</ResourceDictionary>
