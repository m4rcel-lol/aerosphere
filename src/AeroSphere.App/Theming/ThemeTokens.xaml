<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <LinearGradientBrush x:Key="AppShellBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#08111D" Offset="0" />
        <GradientStop Color="#0E1726" Offset="0.45" />
        <GradientStop Color="#142238" Offset="1" />
    </LinearGradientBrush>

    <SolidColorBrush x:Key="NavigationRailBackgroundBrush" Color="#0E1827" />
    <SolidColorBrush x:Key="HeroPanelBackgroundBrush" Color="#15253C" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#162032" />
    <SolidColorBrush x:Key="CardBorderBrush" Color="#263A57" />
    <SolidColorBrush x:Key="CardMutedBrush" Color="#9AA9BF" />
    <SolidColorBrush x:Key="ShellDividerBrush" Color="#22344F" />
    <SolidColorBrush x:Key="AccentSurfaceBrush" Color="#3A6DA8" />
    <SolidColorBrush x:Key="AccentTextBrush" Color="#DCEBFF" />
    <SolidColorBrush x:Key="StatSurfaceBrush" Color="#102840" />

    <Style x:Key="DashboardCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="22" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="MinHeight" Value="180" />
    </Style>

    <Style x:Key="HeroPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource HeroPanelBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="28" />
        <Setter Property="Padding" Value="28" />
    </Style>

    <Style x:Key="DashboardStatStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource StatSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="Padding" Value="16" />
    </Style>

    <Style x:Key="DashboardKickerTextStyle" TargetType="TextBlock">
        <Setter Property="CharacterSpacing" Value="80" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource AccentTextBrush}" />
        <Setter Property="TextWrapping" Value="WrapWholeWords" />
    </Style>

    <Style x:Key="DashboardMetaTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource CardMutedBrush}" />
        <Setter Property="TextWrapping" Value="WrapWholeWords" />
    </Style>

    <Style x:Key="DashboardValueTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="TextWrapping" Value="WrapWholeWords" />
    </Style>
</ResourceDictionary>
